<div id="<%= dom_id listing %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= listing.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= listing.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Price cents:</strong>
    <%= listing.price_cents %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Condition:</strong>
    <%= listing.condition %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Status:</strong>
    <%= listing.status %>
  </div>
  <div>
    <strong class="block font-medium mb-1">User:</strong>
    <%= listing.user_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Category:</strong>
    <%= listing.category_id %>
  </div>
</div>
